# Environment variables for LearnTok
# Copy this file to .env and fill in your values

# Azure OpenAI (uses Entra ID auth via az login, no API key needed)
AZURE_OPENAI_ENDPOINT=https://learn-shared-aoai-test.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-2024-08-06

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-key
COSMOS_DATABASE=learntok

# Azure AI Search (optional, stretch goal)
SEARCH_ENDPOINT=https://your-search.search.windows.net
SEARCH_API_KEY=your-key
SEARCH_INDEX=mslearn

# API
API_PORT=3001
